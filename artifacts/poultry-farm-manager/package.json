{
  "name": "@workspace/poultry-farm-manager",
  "version": "2.0.0",
  "description": "Poultry Farm Management System",
  "main": "out/main/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.config.ts",
    "build": "electron-vite build",
    "download:mongodb": "node scripts/download-mongodb.js",
    "prebuild:win": "pnpm run download:mongodb",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder --win",
    "build:win": "pnpm run build && electron-builder --win --x64",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "catalog:",
    "electron-store": "^11.0.2",
    "extract-zip": "^2.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.545.0",
    "mongodb": "^7.1.1",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zod": "catalog:",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@rollup/rollup-darwin-arm64": "^4.60.1",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.9",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
